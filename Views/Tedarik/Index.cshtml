@model IEnumerable<CamSistemDataLayer.Models.Tedarikci>

@{
    ViewBag.Title = "CamSistem - Tedarik Yönetimi";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<style>
    .row {
        margin-right: 0px;
    }
</style>
<script src="~/plugins/sweetalert/sweetalert.min.js"></script>
<link href="~/plugins/sweetalert/sweetalert.css" rel="stylesheet" />
<script src="~/plugins/jquery/jquery.min.js"></script>
<script type="text/javascript">
    function deleteOrder(_tedarikId) {
        swal({
            title: "Emin misin?",
            text: "Bu kaydı silmek istediğine emin misin?",
            type: "warning",
            showCancelButton: true,
            closeOnConfirm: false,
            cancelButtonText: "İptal",
            confirmButtonClass: "btn-danger",
            confirmButtonText: "Sil",
            confirmButtonColor: "#ec6c62"
        },
        function () {
            $.ajax({
                url: '@Url.Action("TedarikSil", "Tedarik")',
                dataType: 'json',
                data: { "Id": _tedarikId },
                type: "POST"
            })
            .done(function (data) {
                if (data == 'OK') {
                    sweetAlert
                        ({
                            title: "Silindi!",
                            text: "Kayıt başarıyla silindi!",
                            type: "success",
                            timer: 1500
                        },
                            function () {
                                window.location.href = '@Url.Action("Index", "Tedarik")';
                            });
                } else {
                    swal("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                }
            })
            .error(function (data) {
                swal("Oops", "Beklenmedik hata oluştu!", "error");
            });
        });
    }
</script>

<div id="dialog" style="display: none">
</div>

<div id="showmodal" class="modal fade" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @{
                Html.RenderAction("TedarikKaydet", "Tedarik");
            }
        </div>
    </div>
</div>

<div id="showDuzenleModal" class="modal fade" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="result-icerik">

            </div>
        </div>
    </div>
</div>
<!-- JQuery DataTable Css -->


<div class="block-header">
    <h2>
        Tedarik Yönetimi
        <small>Tedarikçilere ait bilgilerin bulunduğu ve bu bilgilerin düzenlenip yenisinin oluşturulabileceği sayfadır.</small>
    </h2>
</div>

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Tedarikçi Listesi
                </h2>
            </div>
            <div class="body">
                <button type="button" data-toggle="modal" data-target="#showmodal" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Tedarikçi Ekle</span>
                </button>
                <div style="padding-top:10px;" class="table-responsive">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Id)</th>
                                <th>@Html.DisplayNameFor(model => model.TedarikciAdi)</th>
                                <th>@Html.DisplayNameFor(model => model.Telefon)</th>
                                <th>@Html.DisplayNameFor(model => model.Adres)</th>
                                <th>@Html.DisplayNameFor(model => model.TedarikciTuru)</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tfoot>
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Id)</th>
                                <th>@Html.DisplayNameFor(model => model.TedarikciAdi)</th>
                                <th>@Html.DisplayNameFor(model => model.Telefon)</th>
                                <th>@Html.DisplayNameFor(model => model.Adres)</th>
                                <th>@Html.DisplayNameFor(model => model.TedarikciTuru)</th>
                                <th>İşlemler</th>
                            </tr>
                        </tfoot>
                        <tbody>
                            @foreach (var item in Model)
                            {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Id)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.TedarikciAdi)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Telefon)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Adres)
                                </td>
                                <td>
                                    @if (item.TedarikciTuru.Equals("Dis"))
                                    {
                                        @Html.Raw("<font>Dış</font>")
                                    }
                                    else
                                    {
                                        @Html.DisplayFor(modelItem => item.TedarikciTuru)
                                    }
                                </td>
                                <td>
                                    <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                            onclick="location.href='@Url.Action("TedarikDuzenle", "Tedarik", new { Id = item.Id })'"
                                            class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                        <i class="material-icons">edit</i>
                                    </button>
                                    <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                            onclick="deleteOrder('@item.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                        <i class="material-icons">delete</i>
                                    </button>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
