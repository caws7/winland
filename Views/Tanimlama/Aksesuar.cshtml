@model IEnumerable<CamSistemDataLayer.Models.Aksesuar>
@{
    ViewBag.Title = "CamSistem - Aksesuar Tanımlama";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<style>
    .row {
        margin-right: 0px;
    }
</style>
<script src="~/plugins/sweetalert/sweetalert.min.js"></script>
<link href="~/plugins/sweetalert/sweetalert.css" rel="stylesheet" />
<script src="~/plugins/jquery/jquery.min.js"></script>
<script type="text/javascript">
    function aksesuarSil(Id) {
        swal({
            title: "Bu aksesuara ait tüm stok bilgisi de silinecektir!",
            text: "Bu kaydı silmek istediğine emin misin?",
            type: "warning",
            showCancelButton: true,
            closeOnConfirm: false,
            cancelButtonText: "İptal",
            confirmButtonClass: "btn-danger",
            confirmButtonText: "Sil",
            confirmButtonColor: "#ec6c62"
        },
        function () {
            $.ajax({
                url: '@Url.Action("AksesuarSil", "Tanimlama")',
                dataType: 'json',
                data: { "Id": Id },
                type: "POST"
            })
            .done(function (data) {
                if (data == 'OK') {
                    sweetAlert
                        ({
                            title: "Silindi!",
                            text: "Kayıt başarıyla silindi!",
                            type: "success",
                            timer: 1500
                        },
                            function () {
                                window.location.href = '@Url.Action("Aksesuar", "Tanimlama")';
                            });
                } else {
                    swal("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                }
            })
            .error(function (data) {
                swal("Oops", "Beklenmedik hata oluştu!", "error");
            });
        });
    }
</script>
<div class="block-header">
    <h2>
        Aksesuar Tanımlama
        <small>Yeni aksesuar tanımlayabileceğiniz ve mevcut aksesuarları düzenleyebileceğiniz sayfadır.</small>
    </h2>
</div>
<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Aksesuar Listesi
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="location.href='@Url.Action("YeniAksesuar", "Tanimlama")'" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Aksesuar Ekle</span>
                </button>
                <div style="padding-top:10px;" class="table-responsive">
                    <table class="table table-bordered table-striped table-hover js-exportable-aksesuar-tanimlama dataTable">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.AksesuarAdi)</th>
                                <th>@Html.DisplayNameFor(model => model.AksesuarGorsel)</th>
                                <th>@Html.DisplayNameFor(model => model.AksesuarKalipNo)</th>
                                <th>@Html.DisplayNameFor(model => model.AksesuarKodu)</th>
                                <th>@Html.DisplayNameFor(model => model.AksesuarBirim)</th>
                                <th>@Html.DisplayNameFor(model => model.BirimFiyat)</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.AksesuarAdi)
                                </td>
                                <td>
                                    @if (item.AksesuarGorsel != null)
                                    {
                                        @Html.Raw("<img class='img-responsive img-thumbnailProf' src = '" + Url.Content("~/images/aksesuaricons/" + item.AksesuarGorsel) + "' />")
                                    }
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.AksesuarKalipNo)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.AksesuarKodu)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.AksesuarBirim)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.BirimFiyat)
                                </td>
                                <td>
                                    <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                            onclick="location.href='@Url.Action("AksesuarDuzenle", "Tanimlama", new { Id = item.Id })'" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                        <i class="material-icons">edit</i>
                                    </button>
                                    &nbsp;
                                    <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                            onclick="aksesuarSil('@item.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                        <i class="material-icons">delete</i>
                                    </button>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>