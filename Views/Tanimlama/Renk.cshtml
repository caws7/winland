@model IEnumerable<CamSistemDataLayer.Models.Renk>

@{
    ViewBag.Title = "CamSistem - Renk Tanımlama";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<style>
    .row {
        margin-right: 0px;
    }
</style>
<script src="//cdn.jsdelivr.net/npm/sweetalert2@10"></script>
<script src="~/plugins/jquery/jquery.min.js"></script>
<script type="text/javascript">
    function yeniRenk() {
        Swal.mixin({
            input: 'text',
            confirmButtonText: 'Devam &rarr;',
            showCancelButton: true,
            cancelButtonText: 'Vazgeç',
            progressSteps: ['1', '2']
        }).queue([
            {
                title: 'Renk Adı',
                inputPlaceholder: "Renk adı giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                }
            },
            {
                title: 'Renk Kodu',
                inputPlaceholder: "Renk kodu giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                }
            }
        ]).then((result) => {
            if (result.value) {
                const answers = JSON.stringify(result.value)
                Swal.fire({
                    title: 'Girilen bilgiler kaydedilsin mi?',
                    html: `Renk Adı, Renk Kodu :<pre><code>${answers}</code></pre>`,
                    confirmButtonText: 'KAYDET'
                }).then((confirm) => {
                    if (confirm.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("YeniRenkEkle", "Tanimlama")',
                            dataType: 'json',
                            data: { "RenkBilgisi": result.value },
                            type: "POST"
                        }).done(function (data) {
                            if (data == 'OK') {
                                Swal.fire({
                                    position: 'top-end',
                                    icon: 'success',
                                    showConfirmButton: false,
                                    timer: 1500,
                                    text: "Kayıt başarıyla oluşturuldu."
                                }).then(() => {
                                    window.location.href = '@Url.Action("Renk", "Tanimlama")';
                                })
                            } else {
                                Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                            }
                        });
                    }
                });
            }
        })
    }

    function renkDuzenle(RenkId) {
        Swal.mixin({
            input: 'text',
            confirmButtonText: 'Devam &rarr;',
            showCancelButton: true,
            cancelButtonText: 'Vazgeç',
            progressSteps: ['1', '2']
        }).queue([
            {
                title: 'Renk Adı',
                inputPlaceholder: "Renk adı giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                }
            },
            {
                title: 'Renk Kodu',
                inputPlaceholder: "Renk kodu giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                }
            }
        ]).then((result) => {
            if (result.value) {
                const answers = JSON.stringify(result.value)
                Swal.fire({
                    title: 'Girilen bilgiler kaydedilsin mi?',
                    html: `Renk Adı, Renk Kodu :<pre><code>${answers}</code></pre>`,
                    confirmButtonText: 'KAYDET'
                }).then((confirm) => {
                    if (confirm.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("RenkDuzenle", "Tanimlama")',
                            dataType: 'json',
                            data: { "RenkId": RenkId, "RenkBilgisi": result.value },
                            type: "POST"
                        }).done(function (data) {
                            if (data == 'OK') {
                                Swal.fire({
                                    position: 'top-end',
                                    icon: 'success',
                                    showConfirmButton: false,
                                    timer: 1500,
                                    text: "Kayıt başarıyla güncellendi."
                                }).then(() => {
                                    window.location.href = '@Url.Action("Renk", "Tanimlama")';
                                })
                            } else {
                                Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                            }
                        });
                    }
                });
            }
        })
    }

    function renkSil(RenkId) {
        Swal.fire({
            title: "Emin misin?",
            text: "Bu kaydı silmek istediğine emin misin?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            cancelButtonText: "İptal",
            confirmButtonText: 'Sil'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("RenkSil", "Tanimlama")',
                    dataType: 'json',
                    data: { "RenkId": RenkId },
                    type: "POST"
                }).done(function (data) {
                    if (data == 'OK') {
                        Swal.fire({
                            position: 'top-end',
                            icon: 'success',
                            showConfirmButton: false,
                            timer: 1500,
                            text: "Kayıt başarıyla silindi."
                        }).then(() => {
                            window.location.href = '@Url.Action("Renk", "Tanimlama")';
                        })
                    } else {
                        Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                    }
                });
            }
        });
    }
</script>
<div class="block-header">
    <h2>
        Renk Tanımlama
        <small>Yeni renk tanımlayabileceğiniz ve mevcut renkleri düzenleyebileceğiniz sayfadır.</small>
    </h2>
</div>
<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Renk Listesi
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="yeniRenk()" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Renk Ekle</span>
                </button>
                <div style="padding-top:10px;" class="table-responsive">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                <th>Renk Id</th>
                                <th>Renk Kodu</th>
                                <th>Renk Adı</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Id)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.RenkKodu)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.RenkAdi)
                                    </td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="renkDuzenle('@item.Id')" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">edit</i>
                                        </button>
                                        &nbsp;
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                onclick="renkSil('@item.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">delete</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>