@model CamSistemDataLayer.Models.Aksesuar

@{
    ViewBag.Title = "CamSistem - Aksesuar Ekle";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<!-- Dropzone Css -->
<link href="~/Scripts/dropzone/dropzone.css" rel="stylesheet" />
<style>
    .dropzone .dz-preview.dz-image-preview {
        background: none;
    }
</style>
<script src="~/plugins/jquery/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        @*document.getElementById("AksesuarKod").style.color = "#c0c0c0";
        $("#AksesuarKod").val('@ViewBag.AksesuarKod');*@

        $('input[type="radio"]').click(function () {
            if ($(this).attr("value") == "tur_motor") {
                $("#AksesuarTuru").val("tur_motor");
            }
            if ($(this).attr("value") == "tur_kumanda") {
                $("#AksesuarTuru").val("tur_kumanda");
            }
        });
    })
</script>
<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Yeni Aksesuar Ekleme
                </h2>
            </div>
            <div class="body">
                @using (Html.BeginForm("YeniAksesuar", "Tanimlama", FormMethod.Post, new { id = "form_validation" }))
                {
                    @Html.AntiForgeryToken()

                <div class="row clearfix">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    <div class="col-sm-6">
                        <div class="form-group form-float">
                            <div class="form-line">
                                @Html.TextBoxFor(model => model.AksesuarAdi, null, new { @class = "form-control", @name = "Aksesuar Adı", @required = "required" })
                                <label class="form-label">Aksesuar Adı</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="form-group form-float">
                            <div class="form-line">
                                @Html.TextBoxFor(model => model.AksesuarKodu, null, new { @class = "form-control", @name = "Aksesuar Kodu", @id = "AksesuarKod",  @required = "required" })
                                <label class="form-label">Aksesuar Kodu</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group form-float">
                            <div class="form-line">
                                @Html.TextBoxFor(model => model.AksesuarKalipNo, null, new { @class = "form-control", @name = "Kalıp No" })
                                <label class="form-label">Kalıp No</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group form-float">
                            <div class="form-line">
                                @Html.TextBoxFor(model => model.BirimFiyat, null, new { @class = "form-control", @name = "Birim Fiyat", @required = "required" })
                                <label class="form-label">Birim Fiyat</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group form-float">
                            <div class="form-line">
                                @Html.TextBoxFor(model => model.AksesuarBirim, null, new { @class = "form-control", @name = "Aksesuar Birim", @required = "required" })
                                <label class="form-label">Aksesuar Birim</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label>Aksesuar Türü</label>
                        <div class="demo-radio-button form-group">
                            <input name="aksesuarTur" type="radio" id="tur_motor" value="tur_motor" class="with-gap radio-col-green aksesuarTur">
                            <label for="tur_motor">Motor</label>
                            <input name="aksesuarTur" type="radio" id="tur_kumanda" value="tur_kumanda" class="with-gap radio-col-green aksesuarTur">
                            <label for="tur_kumanda">Kumanda</label>
                        </div>
                    </div>
                    <div class="row clearfix">
                        <div class="col-md-12">
                            <div id="dZUpload" class="dropzone">
                                <div class="dz-default dz-message">
                                    <div class="drag-icon-cph">
                                        <i class="material-icons">touch_app</i>
                                    </div>
                                    <h3>Görseli yüklemek için tıklayınız.</h3>
                                    <em>(Dosyayı bu alana sürükle bırak yapabilirsiniz.)</em>
                                    <div class="fallback">
                                        <input name="file" id="file" type="file" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="AksesuarTuru" name="AksesuarTuru" />
                    <input type="hidden" id="ImageName" name="ImageName" />
                    <input type="hidden" id="ImageType" name="ImageType" value="A" />
                    <button type="submit" class="btn bg-green waves-effect">KAYDET</button>
                    <button type="button" class="btn bg-black waves-effect waves-light" onclick="location.href='@Url.Action("Aksesuar", "Tanimlama")'" data-dismiss="modal">LİSTEYE GERİ DÖN</button>
                </div>
                }

            </div>
        </div>
    </div>
</div>