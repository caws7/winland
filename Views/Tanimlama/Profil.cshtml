@model IEnumerable<CamSistemDataLayer.Models.Profil>
@{
    ViewBag.Title = "CamSistem - Profil Tanımlama";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<style>
    .row {
        margin-right: 0px;
    }
</style>
<script src="~/plugins/sweetalert/sweetalert.min.js"></script>
<link href="~/plugins/sweetalert/sweetalert.css" rel="stylesheet" />
<script src="~/plugins/jquery/jquery.min.js"></script>
<script type="text/javascript">
    function profilSil(Id) {
        swal({
            title: "Bu profile ait tüm stok bilgisi de silinecektir!",
            text: "Bu profili silmek istediğine emin misin?",
            type: "warning",
            showCancelButton: true,
            closeOnConfirm: false,
            cancelButtonText: "İptal",
            confirmButtonClass: "btn-danger",
            confirmButtonText: "Sil",
            confirmButtonColor: "#ec6c62"
        },
        function () {
            $.ajax({
                url: '@Url.Action("ProfilSil", "Tanimlama")',
                dataType: 'json',
                data: { "Id": Id },
                type: "POST"
            })
            .done(function (data) {
                if (data == 'OK') {
                    sweetAlert
                        ({
                            title: "Silindi!",
                            text: "Kayıt başarıyla silindi!",
                            type: "success",
                            timer: 1500
                        },
                            function () {
                                window.location.href = '@Url.Action("Profil", "Tanimlama")';
                            });
                } else {
                    swal("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                }
            })
            .error(function (data) {
                swal("Oops", "Beklenmedik hata oluştu!", "error");
            });
        });
    }
</script>
<div class="block-header">
    <h2>
        Profil Tanımlama
        <small>Yeni profil tanımlayabileceğiniz ve mevcut profilleri düzenleyebileceğiniz sayfadır.</small>
    </h2>
</div>
<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Profil Listesi
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="location.href='@Url.Action("YeniProfil", "Tanimlama")'" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Profil Ekle</span>
                </button>
                <div style="padding-top:10px;" class="table-responsive">
                    <table class="table table-bordered table-striped table-hover dataTable js-exportable-profil-tanimlama">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Id)</th>
                                <th>@Html.DisplayNameFor(model => model.ProfilFoto)</th>
                                <th>@Html.DisplayNameFor(model => model.ProfilKodu)</th>
                                <th>@Html.DisplayNameFor(model => model.ProfilAdi)</th>
                                <th>@Html.DisplayNameFor(model => model.KalipNo)</th>
                                <th>@Html.DisplayNameFor(model => model.BirimAgirlik)</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Id)
                                    </td>
                                    <td>
                                        @if (item.ProfilFoto != null)
                                        {
                                            @Html.Raw("<img class='img-responsive img-thumbnailProf' src = '" + Url.Content("~/images/profilicons/" + item.ProfilFoto) + "' />")
                                        }
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.ProfilKodu)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.ProfilAdi)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.KalipNo)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.BirimAgirlik)
                                    </td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="location.href='@Url.Action("ProfilDuzenle", "Tanimlama", new { Id = item.Id })'" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">edit</i>
                                        </button>
                                        &nbsp;
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                onclick="profilSil('@item.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">delete</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>