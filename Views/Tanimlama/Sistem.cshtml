@model CamSistemWebArayuz.Models.TanimalamalarModel
@{
    ViewBag.Title = "CamSistem - Sistem Tanımlama";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<style>
    .row {
        margin-right: 0px;
    }
</style>
<!-- JQuery DataTable Css -->
<link href="~/plugins/jquery-datatable/skin/bootstrap/css/dataTables.bootstrap.css" rel="stylesheet">
<script src="//cdn.jsdelivr.net/npm/sweetalert2@10"></script>
<script src="~/plugins/jquery/jquery.min.js"></script>

<script type="text/javascript">
    $(document).ready(function () {

        $('#AltSistemCombo').attr('data-selected-text-format', 'count');

    });
    function yeniTanimlama(_SistemTur) {
        Swal.fire({
            title: 'Yeni kayıt ekleme',
            input: 'text',
            inputLabel: _SistemTur + ' Adı',
            showCancelButton: true,
            cancelButtonText: 'Vazgeç',
            confirmButtonText: 'Kaydet',
            inputPlaceholder: 'Ad giriniz...',
            inputValidator: (value) => {
                if (!value) {
                    return 'Bu alan boş geçilemez!'
                }
            }
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("YeniSistem", "Tanimlama")',
                    dataType: 'json',
                    data: { "SistemAdi": result.value, "SistemTur": _SistemTur },
                    type: "POST"
                }).done(function (data) {
                    if (data == 'OK') {
                        Swal.fire({
                            position: 'top-end',
                            icon: 'success',
                            showConfirmButton: false,
                            timer: 1500,
                            text: "Kayıt başarıyla kaydedildi."
                        }).then(() => {
                            window.location.href = '@Url.Action("Sistem", "Tanimlama")';
                        })
                    } else {
                        Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                    }
                });
            }
        });
    }

    function tanimlamaDuzenleme(_SistemId, _SistemTur, _SistemAd) {
        Swal.fire({
            title: 'Kayıt düzenleme',
            input: 'text',
            inputLabel: _SistemTur + ' Adı',
            showCancelButton: true,
            cancelButtonText: 'Vazgeç',
            confirmButtonText: 'Güncelle',
            inputPlaceholder: 'Ad giriniz...',
            inputValidator: (value) => {
                if (!value) {
                    return 'Bu alan boş geçilemez!'
                }
            },
            inputValue: _SistemAd
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("SistemDuzenle", "Tanimlama")',
                    dataType: 'json',
                    data: { "SistemId": _SistemId, "SistemAdi": result.value, "SistemTur": _SistemTur },
                    type: "POST"
                }).done(function (data) {
                    if (data == 'OK') {
                        Swal.fire({
                            position: 'top-end',
                            icon: 'success',
                            showConfirmButton: false,
                            timer: 1500,
                            text: "Kayıt başarıyla güncellendi."
                        }).then(() => {
                            window.location.href = '@Url.Action("Sistem", "Tanimlama")';
                        })
                    } else {
                        Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                    }
                });
            }
        });
    }

    function tanimlamaSil(_SistemId, _SistemTur) {
        Swal.fire({
            title: 'Emin misin?',
            text: 'Bu kaydı silmek istediğine emin misin?',
            icon: 'warning',
            cancelButtonText: 'Vazgeç',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Evet, sil!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("SistemSil", "Tanimlama")',
                    dataType: 'json',
                    data: { "SistemId": _SistemId, "SistemTur": _SistemTur },
                    type: "POST"
                }).done(function (data) {
                    if (data == 'OK') {
                        Swal.fire({
                            title: 'Silindi!',
                            text: 'Kayıt başarıyla silindi.',
                            icon: 'success',
                            timer: 1500
                        }).then(() => {
                            window.location.href = '@Url.Action("Sistem", "Tanimlama")';
                        });
                    } else {
                        Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                    }
                });
            }
        });
    }

    function baglamaSil(_JoinId) {
        Swal.fire({
            title: 'Emin misin?',
            text: 'Bu kaydı silmek istediğine emin misin?',
            icon: 'warning',
            cancelButtonText: 'Vazgeç',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Evet, sil!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("BaglamaSil", "Tanimlama")',
                    dataType: 'json',
                    data: { "JoinId": _JoinId },
                    type: "POST"
                }).done(function (data) {
                    if (data == 'OK') {
                        Swal.fire({
                            title: 'Silindi!',
                            text: 'Kayıt başarıyla silindi.',
                            icon: 'success',
                            timer: 1500
                        }).then(() => {
                            window.location.href = '@Url.Action("Sistem", "Tanimlama")';
                        });
                    } else {
                        Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                    }
                });
            }
        });
    }
</script>

<div class="block-header">
    <h2>SİSTEM TANIMLAMA</h2>
</div>

<!-- Basic Card -->
<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Bağlanmış Sistem Listesi
                </h2>
            </div>
            <div class="body">
                <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#showBaglaModal">
                    <i class="material-icons">new_releases</i>
                    <span>Sistem Bağla</span>
                </button>
                <div style="padding-top:10px;" class="table-responsive">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                
                                <th>Sistem Adı</th>
                                <th>Sistem Tür Adı</th>
                                <th>Alt Sistem Adı</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.SistemJoinModel)
                            {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.SistemAdi)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.SistemTurAdi)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.AltSistemAdi)
                                </td>
                                <td>
                                    <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                            onclick="baglamaSil('@item.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                        <i class="material-icons">delete</i>
                                    </button>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Sistemler
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="yeniTanimlama('Sistem')" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Sistem Tanımla</span>
                </button>
                <div style="padding-top:10px;">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                <th>Sistem Id</th>
                                <th>Sistem Adı</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.SistemModel)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Id)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.SistemAdi)
                                    </td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="tanimlamaDuzenleme('@item.Id', 'Sistem', '@item.SistemAdi')" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">edit</i>
                                        </button>
                                        &nbsp;
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                onclick="tanimlamaSil('@item.Id', 'Sistem')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">delete</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Sistem Türleri
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="yeniTanimlama('SistemTur')" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Tür Tanımla</span>
                </button>
                <div style="padding-top:10px;">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                <th>Sistem Tür Id</th>
                                <th>Sistem Tür Adı</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.SistemTurModel)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Id)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.TurAdi)
                                    </td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="tanimlamaDuzenleme('@item.Id', 'SistemTur', '@item.TurAdi')" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">edit</i>
                                        </button>
                                        &nbsp;
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                onclick="tanimlamaSil('@item.Id', 'SistemTur')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">delete</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Alt Sistemler
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="yeniTanimlama('AltSistem')" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Alt Sistem Tanımla</span>
                </button>
                <div style="padding-top:10px;">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                <th>Alt Sistem Id</th>
                                <th>Alt Sistem Adı</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.AltSistemModel)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Id)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.AltSistemAdi)
                                    </td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="tanimlamaDuzenleme('@item.Id', 'AltSistem', '@item.AltSistemAdi')" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">edit</i>
                                        </button>
                                        &nbsp;
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                onclick="tanimlamaSil('@item.Id', 'AltSistem')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">delete</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- #END# Basic Card -->
<!-- Modal -->
<div class="modal fade" id="showBaglaModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="showBaglaModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            @using (Html.BeginForm("SistemBaglamaKaydet", "Tanimlama", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
            {
                <div class="modal-header">
                    <h5 class="modal-title" id="showBaglaModalLabel">Sistemleri Bağlama</h5>
                </div>
                <div class="modal-body">
                    <div class="row clearfix">
                        @Html.AntiForgeryToken()
                        <div class="col-sm-6">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.DropDownList("Sistemler", new SelectList(ViewBag.Sistemler, "Id", "SistemAdi"), "Sistem Seçiniz...", new { @class = "form-control show-tick", @id = "SistemCombo" })
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.DropDownList("SistemTurleri", new SelectList(ViewBag.SistemTurleri, "Id", "TurAdi"), "Sistem Türü Seçiniz...", new { @class = "form-control show-tick", @id = "SistemTurCombo" })
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-12">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.DropDownList("AltSistemler", new MultiSelectList(ViewBag.AltSistemler, "Id", "AltSistemAdi"), new { @class = "form-control show-tick", @id = "AltSistemCombo", multiple = "multiple" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn bg-green waves-effect">KAYDET</button>
                    <button type="button" class="btn bg-black waves-effect waves-light" data-dismiss="modal">KAPAT</button>
                </div>
            }
        </div>
    </div>
</div>