@model IEnumerable<CamSistemDataLayer.Models.CamKombinasyon>

@{
    ViewBag.Title = "CamSistem - Cam Kombinasyon Tanımlama";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}
<style>
    .row {
        margin-right: 0px;
    }
</style>
<script src="//cdn.jsdelivr.net/npm/sweetalert2@10"></script>
<script src="~/plugins/jquery/jquery.min.js"></script>
<script>
    function yeniTanimlama() {
        Swal.mixin({
            input: 'text',
            confirmButtonText: 'Devam &rarr;',
            showCancelButton: true,
            cancelButtonText: 'Vazgeç',
            progressSteps: ['1', '2']
        }).queue([
            {
                title: 'Kombinasyon',
                inputPlaceholder: "Kombinasyon adı giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                }
            },
            {
                title: 'Birim Kodu',
                inputPlaceholder: "Birim giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                }
            }
        ]).then((result) => {
            if (result.value) {
                const answers = JSON.stringify(result.value)
                Swal.fire({
                    title: 'Girilen bilgiler kaydedilsin mi?',
                    html: `Kombinasyon, Birim :<pre><code>${answers}</code></pre>`,
                    confirmButtonText: 'KAYDET'
                }).then((confirm) => {
                    if (confirm.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("YeniCam", "Tanimlama")',
                            dataType: 'json',
                            data: { "CamBilgi": result.value },
                            type: "POST"
                        }).done(function (data) {
                            if (data == 'OK') {
                                Swal.fire({
                                    position: 'top-end',
                                    icon: 'success',
                                    showConfirmButton: false,
                                    timer: 1500,
                                    text: "Kayıt başarıyla oluşturuldu."
                                }).then(() => {
                                    window.location.href = '@Url.Action("Cam", "Tanimlama")';
                                })
                            } else {
                                Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                            }
                        });
                    }
                });
            }
        });
    }

    function tanimlamaDuzenleme(_Id, _Cam, _Birim) {
        Swal.mixin({
            input: 'text',
            confirmButtonText: 'Devam &rarr;',
            showCancelButton: true,
            cancelButtonText: 'Vazgeç',
            progressSteps: ['1', '2']
        }).queue([
            {
                title: 'Kombinasyon',
                inputPlaceholder: "Kombinasyon adı giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                },
                inputValue: _Cam
            },
            {
                title: 'Birim Kodu',
                inputPlaceholder: "Birim giriniz...",
                inputValidator: (value) => {
                    if (!value) {
                        return 'Bu alan boş geçilemez!'
                    }
                },
                inputValue: _Birim
            }
        ]).then((result) => {
            if (result.value) {
                const answers = JSON.stringify(result.value)
                Swal.fire({
                    title: 'Girilen bilgiler kaydedilsin mi?',
                    html: `Kombinasyon, Birim :<pre><code>${answers}</code></pre>`,
                    confirmButtonText: 'KAYDET'
                }).then((confirm) => {
                    if (confirm.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("CamDuzenle", "Tanimlama")',
                            dataType: 'json',
                            data: { "Id": _Id, "CamBilgi": result.value },
                            type: "POST"
                        }).done(function (data) {
                            if (data == 'OK') {
                                Swal.fire({
                                    position: 'top-end',
                                    icon: 'success',
                                    showConfirmButton: false,
                                    timer: 1500,
                                    text: "Kayıt başarıyla güncellendi."
                                }).then(() => {
                                    window.location.href = '@Url.Action("Cam", "Tanimlama")';
                                })
                            } else {
                                Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                            }
                        });
                    }
                });
            }
        });
    }

    function tanimlamaSil(_Id, _Tur) {
        Swal.fire({
            title: 'Emin misin?',
            text: 'Bu kaydı silmek istediğine emin misin?',
            icon: 'warning',
            cancelButtonText: 'Vazgeç',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Evet, sil!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("CamSil", "Tanimlama")',
                    dataType: 'json',
                    data: { "Id": _Id, "Tur": _Tur },
                    type: "POST"
                }).done(function (data) {
                    if (data == 'OK') {
                        Swal.fire({
                            title: 'Silindi!',
                            text: 'Kayıt başarıyla silindi.',
                            icon: 'success',
                            timer: 1500
                        }).then(() => {
                            window.location.href = '@Url.Action("Cam", "Tanimlama")';
                        });
                    } else {
                        Swal.fire("Oops", "Beklenmedik hata oluştu! Hata: " + data, "error");
                    }
                });
            }
        });
    }
</script>
<div class="block-header">
    <h2>
        Cam Kombinasyon Tanımlama
        <small>Cam kombinasyon tanımlayabileceğiniz ve kayıtları düzenleyebileceğiniz sayfadır.</small>
    </h2>
</div>

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Cam Kombinasyon Listesi
                </h2>
            </div>
            <div class="body">
                <button type="button" onclick="yeniTanimlama()" class="btn btn-info waves-effect">
                    <i class="material-icons">new_releases</i>
                    <span>Yeni Cam Kombinasyon Tanımla</span>
                </button>
                <div style="padding-top:10px;">
                    <table class="table table-bordered table-striped table-hover js-basic-example dataTable">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Kombinasyon Adı</th>
                                <th>Birim</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Id)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Kombinasyon)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Birim)
                                    </td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="tanimlamaDuzenleme('@item.Id', '@item.Kombinasyon', '@item.Birim')" class="btn bg-green btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">edit</i>
                                        </button>
                                        &nbsp;
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                onclick="tanimlamaSil('@item.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">delete</i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        </div>
    </div>
</div>
