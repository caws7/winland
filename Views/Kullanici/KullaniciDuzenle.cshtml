@model CamSistemDataLayer.Models.Kullanici
@{
    ViewBag.Title = "CamSistem - Müşteri Yönetimi";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
            <div class="header">
                <h2>
                    Kullanıcı Düzenleme
                </h2>
            </div>
            <div class="body">
                @using (Html.BeginForm("KullaniciDuzenle", "Kullanici", FormMethod.Post, new { id = "form_validation" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                    @Html.HiddenFor(model => model.Id)

                    <div class="row clearfix">
                        <div class="col-sm-6">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.TextBoxFor(model => model.KullaniciAdi, null, new { @class = "form-control", @name = "Kullanıcı Adı", @required = "required" })
                                    <label class="form-label">Kullanıcı Adı</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.TextBoxFor(model => model.KullaniciSoyadi, null, new { @class = "form-control", @name = "Kullanıcı Soyadı", @required = "required" })
                                    <label class="form-label">Kullanıcı Soyadı</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.TextBoxFor(model => model.KullaniciMail, null, new { @class = "form-control mail-input-mask", @name = "Kullanıcı Mail", @required = "required" })
                                    <label class="form-label">Kullanıcı Mail</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.TextBoxFor(model => model.Sifre, null, new { @class = "form-control", @name = "Şifre", @required = "required" })
                                    <label class="form-label">Şifre</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-float">
                                <div class="form-line">
                                    @Html.TextBoxFor(model => model.KullaniciTelefon, null, new { @class = "form-control mobile-phone-number", @name = "Telefon" })
                                    <label class="form-label">Telefon</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-12">
                            <div class="form-group">
                                <div class="form-line">
                                    <div class="checkbox">
                                        <input type="checkbox" value="true" id="checkbox1" name="AktifMi" checked="@Model.AktifMi" class="filled-in chk-col-green" />
                                        <label for="checkbox1">Aktif Mi</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn bg-green waves-effect">KAYDET</button>
                    <button type="button" class="btn bg-black waves-effect waves-light" onclick="location.href='@Url.Action("Index", "Kullanici")'" data-dismiss="modal">LİSTEYE GERİ DÖN</button>

                }
            </div>
        </div>
    </div>
</div>
