@model CamSistemWebArayuz.Models.MusteriveAdresModel

<div class="modal-header">
    <h4 class="modal-title" id="largeModalLabel">Müşteri Kaydetme Ekranı</h4>
</div>
<div class="modal-body">
    @using (Html.BeginForm("MusteriKaydet", "Musteri", FormMethod.Post, new { id = "form_validation" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true)
    <div class="row clearfix">
        <div class="col-sm-6">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.MusteriModel.MusteriAdi, null, new { @class = "form-control", @name = "Müşteri Adı", @required = "required" })
                    <label class="form-label">Müşteri Adı</label>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.MusteriModel.MusteriSoyadi, null, new { @class = "form-control", @name = "Müşteri Soyadı", @required = "required" })
                    <label class="form-label">Müşteri Soyadı</label>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.MusteriModel.SirketAdi, null, new { @class = "form-control", @name = "Şirket Adı" })
                    <label class="form-label">Şirket Adı</label>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.MusteriModel.MusteriTelefon, null, new { @class = "form-control mobile-phone-number", @name = "Telefon", @required = "required" })
                    <label class="form-label">Telefon</label>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.AdresModel.Ilce, null, new { @class = "form-control", @name = "İlçe", @minlength = "5", @required = "required" })
                    <label class="form-label">İlçe</label>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.AdresModel.Il, null, new { @class = "form-control", @name = "Şehir", @required = "required" })
                    <label class="form-label">Şehir</label>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.AdresModel.Ulke, null, new { @class = "form-control", @name = "Ülke", @required = "required" })
                    <label class="form-label">Ülke</label>
                </div>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextBoxFor(model => model.AdresModel.PostaKodu, null, new { @class = "form-control zip-code", @name = "Posta Kodu", @minlength = "5", @required = "required" })
                    <label class="form-label">Posta Kodu</label>
                </div>
            </div>
        </div>
        <div class="col-sm-12">
            <div class="form-group form-float">
                <div class="form-line">
                    @Html.TextAreaFor(model => model.AdresModel.AcikAdres, new { @class = "form-control", @rows = 2, @name = "Açık Adres" })
                    <label class="form-label">Açık Adres</label>
                </div>
            </div>
        </div>
    </div>
        <div class="modal-footer">
            <button type="submit" class="btn bg-green waves-effect">KAYDET</button>
            <button type="button" class="btn bg-black waves-effect waves-light" data-dismiss="modal">KAPAT</button>
        </div>
    }
</div>

