@model CamSistemWebArayuz.Models.SiparisStokSablon

<style>
    .modal-body {
        overflow: auto;
    }

    .nav {
        padding-left: revert;
    }
</style>
<ul class="nav nav-tabs tab-nav-right tab-col-red" role="tablist">
    <li role="presentation" class="active"><a href="#imalat" data-toggle="tab"><b>SİPARİŞ BİLGİSİ</b></a></li>
    <li role="presentation"><a href="#camTedarik" data-toggle="tab"><b>CAM TEDARİK BİLGİSİ</b></a></li>
    <li role="presentation"><a href="#boyaTedarik" data-toggle="tab"><b>BOYA TEDARİK BİLGİSİ</b></a></li>
    <li role="presentation"><a href="#disTedarik" data-toggle="tab"><b>DIŞ TEDARİK BİLGİSİ</b></a></li>
    <li role="presentation"><a href="#sevkiyat" data-toggle="tab"><b>SEVKİYAT BİLGİSİ</b></a></li>
    <li role="presentation"><a href="#aciklama" data-toggle="tab"><b>AÇIKLAMA BİLGİSİ</b></a></li>
</ul>

<div class="tab-content">
    <div role="tabpanel" class="tab-pane fade in active" id="imalat">
        <div class="modal-body">
            <div class="modal-body">
                <div id="stoktanSiparisYazdir">
                    <table class="table table-bordered">
                        <tbody>
                            <tr>
                                <td colspan="2" rowspan="3" class="align-middle"><img src="~/images/icons/icon.jpeg" /></td>
                                <td colspan="4" rowspan="3" class="align-middle text-center"><h2>PROFORMA</h2></td>
                                <td colspan="6" class="font-weight-bold text-center">ANKARA</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="font-weight-bold">TEL. 0312 000 00 00</td>
                                <td colspan="3" class="font-weight-bold">CEP: 0530 000 00 00</td>
                            </tr>
                            <tr>
                                <td colspan="6" class="font-weight-bold text-center">mail@mail.com</td>
                            </tr>
                            <tr>
                                <td colspan="2" class="align-middle text-center font-weight-bold">@Model.SirketAd</td>
                                <td class="font-weight-bold">ADRES :</td>
                                <td colspan="9">@Model.SirketAdres</td>
                            </tr>
                            <tr>
                                <td colspan="2" class="font-weight-bold text-right">SİPARİŞ NUMARASI :</td>
                                <td>@Model.SiparisId</td>
                                <td></td>
                                <td colspan="2" class="font-weight-bold text-right">SİPARİŞ TARİHİ :</td>
                                <td colspan="2">@Html.Raw(string.Format("{0:dd/MM/yyyy}", Model.SiparisTarih))</td>
                                <td colspan="2" class="font-weight-bold text-right">TESLİM TARİHİ :</td>
                                <td colspan="2">@Html.Raw(string.Format("{0:dd/MM/yyyy}", Model.TeslimTarihi))</td>
                            </tr>
                            <tr>
                                <td class="font-weight-bold align-middle">KOD</td>
                                <td class="font-weight-bold align-middle">Profil Adı</td>
                                <td class="font-weight-bold align-middle">Profil Kesit</td>
                                <td class="font-weight-bold align-middle">Birim Ağırlık (Kg)</td>
                                <td class="font-weight-bold align-middle">BİRİM</td>
                                <td class="font-weight-bold align-middle">RENK</td>
                                <td class="font-weight-bold align-middle">ÖLÇÜ (m)</td>
                                <td class="font-weight-bold align-middle">MİKTAR</td>
                                <td class="font-weight-bold align-middle">TOPLAM (m)</td>
                                <td class="font-weight-bold align-middle">TOPLAM (Kg)</td>
                                <td class="font-weight-bold align-middle">BİRİM FİYAT (Kg/m)</td>
                                <td class="font-weight-bold align-middle">TOPLAM FİYAT</td>
                            </tr>
                            @foreach (var item in Model.profilList)
                            {
                                <tr>

                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Kodu)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Adi)</td>
                                    <td class="align-middle">@Html.Raw("<img class='img-responsive img-thumbnailProf' src = '" + Url.Content("~/images/profilicons/" + item.Kesit) + "' />")</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.BirimAgirlik)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Birim)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Renk)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Olcu)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Miktar)</td>
                                    <td class="align-middle">@Html.Raw(string.Format("{0:0.00}", item.ToplamMetre))</td>
                                    <td class="align-middle">@Html.Raw(string.Format("{0:0.00}", item.ToplamKg))</td>
                                    <td class="align-middle">@Html.Raw(string.Format("{0:C2}", item.BirimFiyatKgM))</td>
                                    <td class="align-middle">@Html.Raw(string.Format("{0:C2}", item.ToplamTutar))</td>

                                </tr>
                            }
                            <tr>
                                <td colspan="8"></td>
                                <td class="font-weight-bold">TOPLAM:</td>
                                <td class="font-weight-bold">@Html.Raw(string.Format("{0:0.00}", Model.ProfilToplamKg)) Kg</td>
                                <td></td>
                                <td class="font-weight-bold">@Html.Raw(string.Format("{0:C2}", Model.ProfilToplamTutar))</td>
                            </tr>
                            <tr>
                                <td class="font-weight-bold align-middle">KOD</td>
                                <td class="font-weight-bold align-middle">MALZEME</td>
                                <td class="font-weight-bold align-middle">GÖRSELİ</td>
                                <td class="font-weight-bold align-middle">BİRİM</td>
                                <td class="font-weight-bold align-middle">MİKTAR</td>
                                <td class="font-weight-bold align-middle" colspan="5"></td>
                                <td class="font-weight-bold align-middle">BİRİM FİYAT</td>
                                <td class="font-weight-bold align-middle">TOPLAM FİYAT</td>
                            </tr>
                            @foreach (var item in Model.aksesuarList)
                            {
                                <tr>

                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Kodu)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Adi)</td>
                                    <td></td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Birim)</td>
                                    <td class="align-middle">@Html.DisplayFor(modelItem => item.Miktar)</td>
                                    <td class="align-middle" colspan="5"></td>
                                    <td class="align-middle">@Html.Raw(string.Format("{0:C2}", item.BirimFiyat))</td>
                                    <td class="align-middle">@Html.Raw(string.Format("{0:C2}", item.ToplamTutar))</td>

                                </tr>
                            }
                            <tr>
                                <td colspan="10"></td>
                                <td class="font-weight-bold">TOPLAM</td>
                                <td class="font-weight-bold">@Html.Raw(string.Format("{0:C}", Model.AksesuarToplamTutar))</td>
                            </tr>
                            <tr>
                                <td colspan="12"></td>
                            </tr>
                            <tr>
                                <td colspan="9" class="align-middle text-left" rowspan="4">
                                    <ul>
                                        <li>Sevk işlemlerinin yapılabilmesi için açık hesaplarınızın acilen kapanması gerekmektedir.</li>
                                        <li>Bedeli tamamen tahsil edilmemiş malzemeler için, teslimat tarihindeki fiyatlar geçerlidir.</li>
                                        <li>Tarafımıza yazılı olarak onayı gönderilmeyen siparişler işleme alınmayacaktır.</li>
                                        <li>Piyasalardaki hızlı değişimlerden dolayı verilen bu fiyatlar anlıktır. Son onaydan önce fiyatların teyit edilmesi gerekmektedir.</li>
                                        <li>Fiyatlarımız fabrika teslimdir.</li>
                                    </ul>
                                </td>
                                <td colspan="2">GENEL TOPLAM</td>
                                <td>@Html.Raw(string.Format("{0:C2}", (Model.AksesuarToplamTutar + Model.ProfilToplamTutar)))</td>
                            </tr>
                            <tr>
                                <td colspan="2">K.D.V. (%20)</td>
                                <td>@Html.Raw(string.Format("{0:C2}", ((Model.AksesuarToplamTutar + Model.ProfilToplamTutar) * 20 / 100)))</td>
                            </tr>
                            <tr>
                                <td colspan="2" rowspan="2" class="align-middle">K.D.V. DAHİL TOPLAM TUTAR</td>
                                <td rowspan="2" class="align-middle">@Html.Raw(string.Format("{0:C}", (((Model.AksesuarToplamTutar + Model.ProfilToplamTutar) * 20 / 100) + Model.AksesuarToplamTutar + Model.ProfilToplamTutar)))</td>
                            </tr>
                            <tr>
                            </tr>
                            <tr>
                                <td colspan="12" class="align-middle text-center">HESAP NUMARAMIZ - IBAN : TR 00 0000 0000 0000 0000 0000 00</td>
                            </tr>
                        </tbody>
                    </table>
                    @Html.Raw(ViewBag.SiparisAciklamasi)
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" onclick="PrintElem('stoktanSiparisYazdir')" class="btn bg-red waves-effect waves-light">
                    <i class="material-icons">print</i>
                    <span>YAZDIR</span>
                </button>
            </div>
        </div>
    </div>

    <div role="tabpanel" class="tab-pane fade" id="camTedarik">
        <div class="modal-body">
            <div class="tab-content">
                @if (ViewBag.camTedarikVarMi)
                {
                    <div id="camtedarikyazdir">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Sipariş Id</th>
                                    <th>Tedarikçi Adı</th>
                                    <th>Sipariş Onay Tarihi</th>
                                    <th>Termin Tarihi</th>
                                    <th>Güncel Durum</th>
                                    <th>Açıklama</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => Model.CamTedarik.SiparisId)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => Model.CamTedarik.TedarikciAdi)
                                    </td>
                                    <td>
                                        @Html.Raw(string.Format("{0:dd/MM/yyyy}", Model.CamTedarik.SiparisOnayTarihi))
                                    </td>
                                    <td>
                                        @Html.Raw(string.Format("{0:dd/MM/yyyy}", Model.CamTedarik.TerminTarihi))
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => Model.CamTedarik.GuncelDurum)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => Model.CamTedarik.Aciklama)
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <button type="button" onclick="PrintElem('camtedarikyazdir')" class="btn bg-red waves-effect waves-light pull-right">
                        <i class="material-icons">print</i>
                        <span>YAZDIR</span>
                    </button>
                    <br /><br /><br />
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Dosya Adı</th>
                                <th>Dosya Uzantısı</th>
                                <th>Dosya Yükleme Tarihi</th>
                                <th>#</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var camTedarik in ViewBag.camTedarikList)
                            {
                                <tr>
                                    <td>@camTedarik.DosyaAdi</td>
                                    <td>@camTedarik.DosyaUzantisi</td>
                                    <td>@Html.Raw(string.Format("{0:dd/MM/yyyy HH:mm:dd}", camTedarik.YuklenmeTarihi))</td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="Düzenle"
                                                onclick="location.href='@Url.Action("DosyaIndir", "Siparis", new { Id = camTedarik.Id })'" class="btn bg-blue btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">file_download</i>
                                        </button>
                                        &nbsp;
                                        @*<button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                    onclick="dosyaSil('@camTedarik.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                                <i class="material-icons">delete</i>
                                            </button>*@
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    if (ViewBag.SiparisDurumu)
                    {
                        <button type="button" onclick="location.href='@Url.Action("CamTedarikKaydet", "Tedarik", new { SiparisId = Model.SiparisId })'" class="btn btn-info waves-effect">
                            <i class="material-icons">new_releases</i>
                            <span>Cam Tedarik Bilgisi Oluştur</span>
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <strong>Onaylandı ve Sevkiyata Hazır</strong> durumundaki siparişler için tedarik bilgisi oluşturulur!
                        </div>
                    }
                }
            </div>
        </div>
    </div>

