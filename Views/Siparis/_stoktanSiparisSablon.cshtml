                                    </td>
                                    <td>
                                        @Html.Raw(string.Format("{0:dd/MM/yyyy}", Model.BoyaTedarik.GelisTarihi))
                                    </td>
                                    <td>
                                        @Html.Raw(string.Format("{0:dd/MM/yyyy}", Model.BoyaTedarik.CikisTarihi))
                                    </td>

                                    <td>
                                        @Html.DisplayFor(modelItem => Model.BoyaTedarik.Aciklama)
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <button type="button" onclick="PrintElem('boyatedarikyazdir')" class="btn bg-red waves-effect waves-light pull-right">
                        <i class="material-icons">print</i>
                        <span>YAZDIR</span>
                    </button>
                    <br /><br /><br />
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Dosya Adı</th>
                                <th>Dosya Uzantısı</th>
                                <th>Dosya Yükleme Tarihi</th>
                                <th>#</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var boyaTedarik in ViewBag.boyaTedarikList)
                            {
                                <tr>
                                    <td>@boyaTedarik.DosyaAdi</td>
                                    <td>@boyaTedarik.DosyaUzantisi</td>
                                    <td>@Html.Raw(string.Format("{0:dd/MM/yyyy HH:mm:dd}", boyaTedarik.YuklenmeTarihi))</td>
                                    <td>
                                        <button type="button" data-toggle="tooltip" data-placement="top" title="İndir"
                                                onclick="location.href='@Url.Action("DosyaIndir", "Siparis", new { Id = boyaTedarik.Id })'" class="btn bg-blue btn-circle waves-effect waves-circle waves-float">
                                            <i class="material-icons">file_download</i>
                                        </button>
                                        &nbsp;
                                        @*<button type="button" data-toggle="tooltip" data-placement="top" title="Sil"
                                                    onclick="dosyaSil('@camTedarik.Id')" class="btn btn-danger btn-circle waves-effect waves-circle waves-float">
                                                <i class="material-icons">delete</i>
                                            </button>*@
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    if (ViewBag.SiparisDurumu)
                    {
                        <button type="button" onclick="location.href='@Url.Action("BoyaTedarikKaydet", "Tedarik", new { SiparisId = Model.SiparisId })'" class="btn btn-info waves-effect">
                            <i class="material-icons">new_releases</i>
                            <span>Boya Tedarik Bilgisi Oluştur</span>
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <strong>Onaylandı ve Sevkiyata Hazır</strong> durumundaki siparişler için tedarik bilgisi oluşturulur!
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div role="tabpanel" class="tab-pane fade" id="disTedarik">
        <div class="modal-body">
            <div class="tab-content">
                @if (ViewBag.disTedarikVarMi)
                {
                    <div id="distedarikyazdir">
