<style>
    .row {
        margin-right: 0px;
    }
</style>
<script src="//cdn.jsdelivr.net/npm/sweetalert2@10"></script>
<script src="~/plugins/jquery/jquery.min.js"></script>
<script src="~/Scripts/jspdf.umd.js"></script>
<script src="~/Scripts/html2canvas.min.js"></script>
<script language="javascript" type="text/javascript">
    $(function () {
        //Remove the dummy row if data present.
        if ($(".customeditabletable tr").length > 2) {
            $(".customeditabletable tr:eq(1)").remove();
            $(".customeditabletable tr:eq(2)").remove();
        } else {
            var row = $(".customeditabletable tr:last-child");
            row.find(".Edit").hide();
            row.find(".Delete").hide();
        }
    });
    $("body").on("click", ".customeditabletable .Cancel", function () {
        var row = $(this).closest("tr");
        $("td", row).each(function () {
            if ($(this).find("input").length > 0) {
                var span = $(this).find("span");
                var input = $(this).find("input");
                input.val(span.html());
                span.show();
                input.hide();
            }
        });
        row.find(".Edit").show();
        row.find(".Delete").show();
        row.find(".Update").hide();
        $(this).hide();
    });
    $("body").on("click", ".customeditabletable .Edit", function () {
        var row = $(this).closest("tr");
        $("td", row).each(function () {
            if ($(this).find("input").length > 0) {
                $(this).find("input").show();
                $(this).find("span").hide();
            }
        });
        row.find(".Update").show();
        row.find(".Cancel").show();
        $(this).hide();
    });
    $("body").on("click", ".customeditabletable .Update", function () {
        var row = $(this).closest("tr");
        $("td", row).each(function () {
            if ($(this).find("input").length > 0) {
                var span = $(this).find("span");
                var input = $(this).find("input");
                span.html(input.val());
                span.show();
                input.hide();
            }
        });
        row.find(".Edit").show();
        row.find(".Cancel").hide();
        $(this).hide();

        var siparisTeklif = {};
        siparisTeklif.Id = row.find(".TeklifId").find("span").html();
        siparisTeklif.SiparisEnBoyAdetId = row.find(".SiparisEnBoyAdetId").find("span").html();
        //siparisTeklif.Malzeme = row.find(".Malzeme").find("span").html();
        siparisTeklif.Birim = row.find(".Birim").find("span").html();
        siparisTeklif.Miktar = row.find(".Miktar").find("span").html();
        siparisTeklif.BirimFiyat = row.find(".BirimFiyat").find("span").html();
        //siparisTeklif.ToplamTutar = row.find(".ToplamTutar").find("span").html();

        $.ajax({
            type: "POST",
            url: "/Siparis/TeklifDuzenle",
            data: '{siparisTeklif:' + JSON.stringify(siparisTeklif) + '}',
            contentType: "application/json; charset=utf-8",
            dataType: "json"
        }).done(function (data) {
            $("#" + data.Id + "-message-visible").show();
        });
    });

    function SiparisDetayiGoruntule(_siparisId) {
        var url = '@Url.Action("SiparisDetayGoruntule", "Siparis")';

        $('#searchResults').load(url, { SiparisId: _siparisId, raporMu: false });
        $('#showDuzenleModal').modal('show');
    }

    function SiparisIndir(_siparisId) {
        var excelName = _siparisId + "_nolu_siparis" + ".xlsx";
        var pdfName = _siparisId + "_nolu_siparis" + ".pdf";

        Swal.fire({
            title: 'Hangi formatta indirmek istesiniz?',
            showDenyButton: true,
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            denyButtonColor: '#d33',
            cancelButtonText: `Vazgeç`,
            confirmButtonText: `Excel İndir`,
            denyButtonText: `Pdf İndir`,
        }).then((result) => {
            /* Read more about isConfirmed, isDenied below */
            if (result.isConfirmed) {
                window.location.href = "@Url.RouteUrl(new
                                   { Controller = "Siparis", Action = "SiparisIndir" })/?file=" + excelName;
            } else if (result.isDenied) {
                 $.ajax({
                    url: '@Url.Action("SiparisPdfYazdir", "Siparis")',
                    contentType: 'application/html; charset=utf-8',
                    type: 'GET',
                    data: { 'SiparisId': _siparisId },
                    dataType: 'html'
                })
                .success(function (result) {
                    $("#yazdirPdfKayitlar").css("visibility", "visible");
                    $('#yazdirPdfKayitlar').html(result);
                    var doc = window.jspdf.jsPDF("portrait");

                    html2canvas($("#yazdirPdfKayitlar")[0]).then((canvas) => {
                        const pageWidth = doc.internal.pageSize.getWidth();
                        const pageHeight = doc.internal.pageSize.getHeight();

                        const widthRatio = pageWidth / canvas.width;
                        const heightRatio = pageHeight / canvas.height;
                        const ratio = widthRatio > heightRatio ? heightRatio : widthRatio;

                        const canvasWidth = canvas.width * ratio;
                        const canvasHeight = canvas.height * ratio;

                        //const marginX = (pageWidth - canvasWidth) / 10;
                        //const marginY = (pageHeight - canvasHeight) / 10;

                        doc.addImage(canvas, 'JPEG', 10, 10, 190, canvasHeight);

                        doc.save(pdfName);
                        $("#yazdirPdfKayitlar").css("visibility", "hidden");
                   });
                })
            }
        })
    }

