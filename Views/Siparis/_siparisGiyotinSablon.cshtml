<script>
    function dosyaSil(_this, _Id, _siparisId, _tur) {
        Swal.fire({
            title: 'Emin misin?',
            text: 'Bu kaydı silmek istediğine emin misin?',
            icon: 'warning',
            cancelButtonText: 'Vazgeç',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Evet, sil!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("DosyaSil", "Siparis")',
                    contentType: 'application/json; charset=utf-8',
                    dataType: 'json',
                    data: '{ "dosyaId":"' + _Id + '", "siparisId":"' + _siparisId + '", "dosyaTur":"' + _tur + '"}',
                    success: function (data) {
                        if (data == 'OK') {
                            $(_this).closest("tr").remove();
                            Swal.fire({
                                position: 'top-end',
                                icon: 'success',
                                title: 'Silme işlemi başarıyla gerçekleştirildi.',
                                showConfirmButton: false,
                                timer: 1500
                            })
                        }
                    },
                    error: function (err) {
                        console.log(err);
                    }
                });
            }
        });
    }

    $(document).ready(function () {

         $('#aciklamaDosyaKaydet').click(function () {

            // Checking whether FormData is available in browser
            if (window.FormData !== undefined) {

                var siparisId = $("#siparisId").val();
                var fileUpload = $("#aciklamaDosyaInputId").get(0);
                var files = fileUpload.files;

                var fileData = new FormData();

                for (var i = 0; i < files.length; i++) {
                    fileData.append(files[i].name, files[i]);
                }
                fileData.append('siparisId', siparisId);

                $.ajax({
                    url: '@Url.Action("AciklamaDosyaYukleme", "Siparis")',
                    type: "POST",
                    contentType: false, // Not to set any content header
                    processData: false, // Not to process data
                    data: fileData,
                    success: function (data) {
                        if (data.result == "OK") {
                            Swal.fire({
                                title: 'Başarılı!',
                                text: 'Dosya yükleme işlemi başarıyla gerçekleştirildi!',
                                icon: 'success',
                                timer: 1500
                            }).then(() => {
                                window.location.href = '@Url.Action("Index", "Siparis")';
                            });
                            $('#showDuzenleModal').modal('toggle');
                            window.setTimeout(function () { location.reload() }, 1800)
                        } else if (data.result == "NOK") {
                            $('#aciklamaDosyaInputId').val('');
                            $('#result').html(data.mesaj);
                        } else if (data.result == "WOK") {
                            $('#aciklamaDosyaInputId').val('');
                            $('#result').html(data.mesaj);
                        }
                    },
                    error: function (err) {
                        alert(err.statusText);
                    }
                });
            } else {
                alert("FormData is not supported.");
            }
        });
    });
</script>

